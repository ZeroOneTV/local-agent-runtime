# Perfil performance (~64 GB RAM)
APP_PERFORMANCE_PROFILE=performance
APP_ROLE=api
NODE_OPTIONS=--max-old-space-size=1024

MAX_CONTEXT_TOKENS=16384
CONTEXT_RECENT_MESSAGES=16
CONTEXT_SKIP_RAG_CASUAL=true
RAG_TOP_K=8

JOBS_ORCHESTRATOR_CONCURRENCY=2
JOBS_INDEXING_CONCURRENCY=4
JOBS_EMBEDDINGS_CONCURRENCY=2
JOBS_TOOLS_CONCURRENCY=4
JOBS_MEMORY_CONCURRENCY=2
JOBS_MEDIA_CONCURRENCY=2

MEMORY_RETRIEVAL_MAX_RECENT=8
MEMORY_RETRIEVAL_MAX_CONSOLIDATED=8
MEMORY_RETRIEVAL_MAX_DEEP=4

MEDIA_DEFAULT_PROCESSING_MODE=balanced
MEDIA_ENABLE_VLM=true
MEDIA_ENABLE_DOCLING=true

RESOURCE_GUARD_MAX_RAM_PERCENT=85
RESOURCE_GUARD_MAX_CPU_PERCENT=90

TOOL_RESULT_INLINE_MAX_KB=64
CONTEXT_ARTIFACT_PREVIEW_MAX_KB=24

REDIS_MAXMEMORY=512mb
POSTGRES_SHARED_BUFFERS=512MB
POSTGRES_WORK_MEM=16MB
POSTGRES_MAINTENANCE_WORK_MEM=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=2GB
