# Modo docker-mounted — backend no Docker, pastas montadas como volumes
HOST_FILESYSTEM_ENABLED=true
HOST_FILESYSTEM_MODE=docker-mounted
HOST_FILESYSTEM_ALLOW_BROWSE=true
HOST_FILESYSTEM_ALLOW_READ=true
HOST_FILESYSTEM_ALLOW_WRITE=false
HOST_FILESYSTEM_REQUIRE_APPROVAL_FOR_WRITE=true
HOST_FILESYSTEM_REQUIRE_APPROVAL_FOR_DELETE=true
HOST_FILESYSTEM_BLOCK_SENSITIVE_PATHS=true
HOST_FILESYSTEM_AUDIT_ENABLED=true

# Ajuste hostPrefix para seu usuário (Linux/WSL ou Windows)
HOST_FILESYSTEM_MOUNTS_JSON=[{"hostPrefix":"/home/yourname","containerPrefix":"/host/home","access":"read"},{"hostPrefix":"/home/yourname/my_llm","containerPrefix":"/workspace","access":"read"}]
