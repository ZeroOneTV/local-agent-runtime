# Dependencies
node_modules/
.next/
dist/

# Environment
.env
.env.local
.env.*.local

# Storage (keep structure, ignore runtime contents)
storage/uploads/*
storage/projects/*
storage/generated/*
storage/temp/*
storage/media/images/originals/*
storage/media/images/thumbnails/*
storage/media/images/processed/*
storage/media/images/contexts/*
