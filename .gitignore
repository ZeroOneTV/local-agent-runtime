__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
*.egg-info/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Docker local bind mounts (named volumes are managed by Docker)
postgres_data/
redis_data/
qdrant_data/
open_webui_data/

# Prisma
backend/prisma/migrations/**/migration_lock.toml

# Logs
*.log
npm-debug.log*
