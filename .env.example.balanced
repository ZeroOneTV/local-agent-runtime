# Perfil balanced (~32 GB RAM) — padrão recomendado
APP_PERFORMANCE_PROFILE=balanced
APP_ROLE=api
NODE_OPTIONS=--max-old-space-size=768

MAX_CONTEXT_TOKENS=8192
CONTEXT_RECENT_MESSAGES=12
CONTEXT_SKIP_RAG_CASUAL=true
RAG_TOP_K=5

JOBS_ORCHESTRATOR_CONCURRENCY=1
JOBS_INDEXING_CONCURRENCY=2
JOBS_EMBEDDINGS_CONCURRENCY=1
JOBS_TOOLS_CONCURRENCY=2
JOBS_MEMORY_CONCURRENCY=1
JOBS_MEDIA_CONCURRENCY=1

MEMORY_RETRIEVAL_MAX_RECENT=5
MEMORY_RETRIEVAL_MAX_CONSOLIDATED=5
MEMORY_RETRIEVAL_MAX_DEEP=2

MEDIA_DEFAULT_PROCESSING_MODE=balanced
MEDIA_ENABLE_VLM=false
MEDIA_ENABLE_DOCLING=true

RESOURCE_GUARD_MAX_RAM_PERCENT=80
RESOURCE_GUARD_MAX_CPU_PERCENT=85

TOOL_RESULT_INLINE_MAX_KB=32
CONTEXT_ARTIFACT_PREVIEW_MAX_KB=16

REDIS_MAXMEMORY=512mb
POSTGRES_SHARED_BUFFERS=512MB
POSTGRES_WORK_MEM=16MB
POSTGRES_MAINTENANCE_WORK_MEM=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=2GB
