generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String?
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projects Project[]

  @@map("users")
}

model Project {
  id            String   @id @default(uuid()) @db.Uuid
  ownerId       String   @map("owner_id") @db.Uuid
  name          String
  description   String?
  rootPath      String?  @map("root_path")
  executionMode String   @default("developer") @map("execution_mode")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  files         File[]
  memories      Memory[]
  jobs          Job[]

  @@map("projects")
}

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  title     String?
  model     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project   Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  Message[]
  summaries ConversationSummary[]
  toolCalls ToolCall[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String
  content        String
  tokenCount     Int?     @map("token_count")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation          Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  summariesGeneratedFor ConversationSummary[] @relation("SummaryUntilMessage")

  @@map("messages")
}

model ConversationSummary {
  id                      String   @id @default(uuid()) @db.Uuid
  conversationId          String   @map("conversation_id") @db.Uuid
  summary                 String
  generatedUntilMessageId String?  @map("generated_until_message_id") @db.Uuid
  createdAt               DateTime @default(now()) @map("created_at")

  conversation          Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  generatedUntilMessage Message?     @relation("SummaryUntilMessage", fields: [generatedUntilMessageId], references: [id], onDelete: SetNull)

  @@map("conversation_summaries")
}

model File {
  id              String    @id @default(uuid()) @db.Uuid
  projectId       String    @map("project_id") @db.Uuid
  path            String
  filename        String
  extension       String?
  documentType    String?   @map("document_type")
  hash            String?
  size            Int?
  priority        Int       @default(3)
  lastModified    DateTime? @map("last_modified")
  indexedAt       DateTime? @map("indexed_at")
  embeddingModel  String?   @map("embedding_model")
  chunkConfigHash String?   @map("chunk_config_hash")
  deletedAt       DateTime? @map("deleted_at")

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chunks  FileChunk[]

  @@unique([projectId, path])
  @@map("files")
}

model FileChunk {
  id         String @id @default(uuid()) @db.Uuid
  fileId     String @map("file_id") @db.Uuid
  chunkIndex Int    @map("chunk_index")
  content    String
  tokenCount Int?   @map("token_count")

  file      File       @relation(fields: [fileId], references: [id], onDelete: Cascade)
  embedding Embedding?

  @@map("file_chunks")
}

model Embedding {
  id             String                      @id @default(uuid()) @db.Uuid
  chunkId        String                      @unique @map("chunk_id") @db.Uuid
  embeddingModel String                      @map("embedding_model")
  vector         Unsupported("vector(1536)")?
  createdAt      DateTime                    @default(now()) @map("created_at")

  chunk FileChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@map("embeddings")
}

model Memory {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @map("project_id") @db.Uuid
  title      String
  content    String
  importance Int      @default(3)
  origin     String   @default("user_confirmation")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  history MemoryHistory[]

  @@map("memories")
}

model MemoryHistory {
  id              String   @id @default(uuid()) @db.Uuid
  memoryId        String   @map("memory_id") @db.Uuid
  action          String
  previousTitle   String?  @map("previous_title")
  previousContent String?  @map("previous_content")
  newTitle        String?  @map("new_title")
  newContent      String?  @map("new_content")
  reason          String?
  createdAt       DateTime @default(now()) @map("created_at")

  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@map("memory_history")
}

model FileDeletionAudit {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  filePath  String   @map("file_path")
  filename  String
  hash      String?
  deletedAt DateTime @default(now()) @map("deleted_at")

  @@map("file_deletion_audit")
}

model ToolCall {
  id             String    @id @default(uuid()) @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  toolName       String    @map("tool_name")
  parameters     Json
  status         String    @default("pending")
  startedAt      DateTime  @default(now()) @map("started_at")
  finishedAt     DateTime? @map("finished_at")
  approvedBy     String?   @map("approved_by") @db.Uuid
  approvedAt     DateTime? @map("approved_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  result       ToolResult?

  @@map("tool_calls")
}

model ToolResult {
  id            String  @id @default(uuid()) @db.Uuid
  toolCallId    String  @unique @map("tool_call_id") @db.Uuid
  output        String
  executionTime Int?    @map("execution_time")
  success       Boolean @default(true)

  toolCall ToolCall @relation(fields: [toolCallId], references: [id], onDelete: Cascade)

  @@map("tool_results")
}

model Job {
  id         String    @id @default(uuid()) @db.Uuid
  projectId  String?   @map("project_id") @db.Uuid
  type       String
  status     String    @default("pending")
  payload    Json?
  result     Json?
  error      Json?
  createdAt  DateTime  @default(now()) @map("created_at")
  startedAt  DateTime? @map("started_at")
  finishedAt DateTime? @map("finished_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("jobs")
}

model Setting {
  id    String @id @default(uuid()) @db.Uuid
  key   String @unique
  value String

  @@map("settings")
}

model ToolAuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  conversationId String?  @map("conversation_id") @db.Uuid
  toolCallId     String?  @map("tool_call_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  toolName       String   @map("tool_name")
  parameters     Json
  result         Json?
  success        Boolean?
  executionTime  Int?     @map("execution_time")
  approved       Boolean  @default(false)
  approvedBy     String?  @map("approved_by") @db.Uuid
  errorCode      String?  @map("error_code")
  policyBlocked  Boolean  @default(false) @map("policy_blocked")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@index([conversationId])
  @@map("tool_audit_logs")
}

model OrchestratorEvent {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  conversationId String?  @map("conversation_id") @db.Uuid
  type           String
  payload        Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@index([conversationId])
  @@map("orchestrator_events")
}
