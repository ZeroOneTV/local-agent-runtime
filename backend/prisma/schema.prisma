generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String?
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projects Project[]

  @@map("users")
}

model Project {
  id            String   @id @default(uuid()) @db.Uuid
  ownerId       String   @map("owner_id") @db.Uuid
  name          String
  description   String?
  rootPath      String?  @map("root_path")
  executionMode String   @default("developer") @map("execution_mode")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  files         File[]
  memories      Memory[]
  jobs                 Job[]
  mediaAssets          MediaAsset[]
  recentMemoryItems    RecentMemoryItem[]
  deepMemoryItems      DeepMemoryItem[]
  archiveItems         ArchiveItem[]
  memoryAccessLogs     MemoryAccessLog[]
  memoryPortabilityRecords MemoryPortabilityRecord[]
  filesystemPermissions ProjectFilesystemPermission[]

  @@map("projects")
}

model ProjectFilesystemPermission {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @map("project_id") @db.Uuid
  mode            String
  hostPrefix      String   @map("host_prefix")
  containerPrefix String?  @map("container_prefix")
  accessLevel     String   @map("access_level")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_filesystem_permissions")
}

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  title     String?
  model     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project   Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  Message[]
  summaries ConversationSummary[]
  toolCalls ToolCall[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String
  content        String
  tokenCount     Int?     @map("token_count")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation          Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  summariesGeneratedFor ConversationSummary[] @relation("SummaryUntilMessage")

  @@index([conversationId])
  @@map("messages")
}

model ConversationSummary {
  id                      String   @id @default(uuid()) @db.Uuid
  conversationId          String   @map("conversation_id") @db.Uuid
  summary                 String
  generatedUntilMessageId String?  @map("generated_until_message_id") @db.Uuid
  createdAt               DateTime @default(now()) @map("created_at")

  conversation          Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  generatedUntilMessage Message?     @relation("SummaryUntilMessage", fields: [generatedUntilMessageId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@map("conversation_summaries")
}

model File {
  id              String    @id @default(uuid()) @db.Uuid
  projectId       String    @map("project_id") @db.Uuid
  path            String
  filename        String
  extension       String?
  documentType    String?   @map("document_type")
  hash            String?
  size            Int?
  priority        Int       @default(3)
  lastModified    DateTime? @map("last_modified")
  indexedAt       DateTime? @map("indexed_at")
  embeddingModel  String?   @map("embedding_model")
  chunkConfigHash String?   @map("chunk_config_hash")
  deletedAt       DateTime? @map("deleted_at")

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chunks  FileChunk[]

  @@unique([projectId, path])
  @@index([projectId])
  @@index([hash])
  @@map("files")
}

model FileChunk {
  id         String @id @default(uuid()) @db.Uuid
  fileId     String @map("file_id") @db.Uuid
  chunkIndex Int    @map("chunk_index")
  content    String
  tokenCount Int?   @map("token_count")

  file      File       @relation(fields: [fileId], references: [id], onDelete: Cascade)
  embedding Embedding?

  @@index([fileId])
  @@map("file_chunks")
}

model Embedding {
  id             String                      @id @default(uuid()) @db.Uuid
  chunkId        String                      @unique @map("chunk_id") @db.Uuid
  embeddingModel String                      @map("embedding_model")
  vector         Unsupported("vector(1536)")?
  createdAt      DateTime                    @default(now()) @map("created_at")

  chunk FileChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@map("embeddings")
}

model Memory {
  id             String    @id @default(uuid()) @db.Uuid
  projectId      String    @map("project_id") @db.Uuid
  title          String
  content        String
  importance     Int       @default(3)
  origin         String    @default("user_confirmation")
  active         Boolean   @default(true)
  confidence     Float     @default(1)
  sourceType     String?   @map("source_type")
  sourceRef      String?   @map("source_ref")
  lastAccessedAt DateTime? @map("last_accessed_at")
  accessCount    Int       @default(0) @map("access_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  history MemoryHistory[]

  @@index([projectId])
  @@index([active])
  @@map("memories")
}

model RecentMemoryItem {
  id                 String    @id @default(uuid()) @db.Uuid
  projectId          String    @map("project_id") @db.Uuid
  conversationId     String?   @map("conversation_id") @db.Uuid
  title              String
  content            String
  summary            String?
  sourceType         String    @map("source_type")
  sourceRef          String?   @map("source_ref")
  importance         Int       @default(3)
  confidence         Float     @default(0.7)
  status             String    @default("active")
  expiresAt          DateTime? @map("expires_at")
  promotedToMemoryId String?   @map("promoted_to_memory_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  lastAccessedAt     DateTime? @map("last_accessed_at")
  accessCount        Int       @default(0) @map("access_count")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([conversationId])
  @@index([status])
  @@index([expiresAt])
  @@map("recent_memory_items")
}

model DeepMemoryItem {
  id               String    @id @default(uuid()) @db.Uuid
  projectId        String    @map("project_id") @db.Uuid
  title            String
  summary          String?
  contentPreview   String?   @map("content_preview")
  sourceType       String    @map("source_type")
  sourceRef        String?   @map("source_ref")
  artifactPath     String?   @map("artifact_path")
  contextPath      String?   @map("context_path")
  documentType     String?   @map("document_type")
  tags             String[]  @default([])
  entities         Json?
  embeddingStatus  String    @default("not_indexed") @map("embedding_status")
  embeddingModel   String?   @map("embedding_model")
  chunkConfigHash  String?   @map("chunk_config_hash")
  importance       Int       @default(2)
  confidence       Float     @default(0.6)
  createdAt        DateTime  @default(now()) @map("created_at")
  lastAccessedAt   DateTime? @map("last_accessed_at")
  accessCount      Int       @default(0) @map("access_count")
  archivedAt       DateTime? @map("archived_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([embeddingStatus])
  @@index([archivedAt])
  @@map("deep_memory_items")
}

model ArchiveItem {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  archiveType String    @map("archive_type")
  title       String
  summary     String?
  storagePath String    @map("storage_path")
  manifestRef String?   @map("manifest_ref")
  checksum    String?
  sizeBytes   Int?      @map("size_bytes")
  compressed  Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  restoredAt  DateTime? @map("restored_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([archiveType])
  @@map("archive_items")
}

model MemoryAccessLog {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  conversationId String?  @map("conversation_id") @db.Uuid
  memoryLayer    String   @map("memory_layer")
  memoryRefId    String   @map("memory_ref_id") @db.Uuid
  query          String?
  score          Float?
  reason         String?
  accessedAt     DateTime @default(now()) @map("accessed_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([memoryLayer])
  @@map("memory_access_logs")
}

model MemoryPortabilityRecord {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String?   @map("project_id") @db.Uuid
  recordType  String    @map("record_type")
  profile     String?
  status      String    @default("pending")
  filePath    String?   @map("file_path")
  manifest    Json?
  report      Json?
  error       Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([recordType])
  @@index([status])
  @@map("memory_portability_records")
}

model MemoryHistory {
  id              String   @id @default(uuid()) @db.Uuid
  memoryId        String   @map("memory_id") @db.Uuid
  action          String
  previousTitle   String?  @map("previous_title")
  previousContent String?  @map("previous_content")
  newTitle        String?  @map("new_title")
  newContent      String?  @map("new_content")
  reason          String?
  createdAt       DateTime @default(now()) @map("created_at")

  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@map("memory_history")
}

model FileDeletionAudit {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  filePath  String   @map("file_path")
  filename  String
  hash      String?
  deletedAt DateTime @default(now()) @map("deleted_at")

  @@map("file_deletion_audit")
}

model ToolCall {
  id             String    @id @default(uuid()) @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  toolName       String    @map("tool_name")
  parameters     Json
  status         String    @default("pending")
  startedAt      DateTime  @default(now()) @map("started_at")
  finishedAt     DateTime? @map("finished_at")
  approvedBy     String?   @map("approved_by") @db.Uuid
  approvedAt     DateTime? @map("approved_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  result       ToolResult?

  @@index([conversationId])
  @@map("tool_calls")
}

model ToolResult {
  id            String  @id @default(uuid()) @db.Uuid
  toolCallId    String  @unique @map("tool_call_id") @db.Uuid
  output        String
  artifactPath  String? @map("artifact_path")
  executionTime Int?    @map("execution_time")
  success       Boolean @default(true)

  toolCall ToolCall @relation(fields: [toolCallId], references: [id], onDelete: Cascade)

  @@map("tool_results")
}

model Job {
  id         String    @id @default(uuid()) @db.Uuid
  projectId  String?   @map("project_id") @db.Uuid
  type       String
  status     String    @default("pending")
  payload    Json?
  result     Json?
  error      Json?
  createdAt  DateTime  @default(now()) @map("created_at")
  startedAt  DateTime? @map("started_at")
  finishedAt DateTime? @map("finished_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([type])
  @@index([projectId])
  @@map("jobs")
}

model Setting {
  id    String @id @default(uuid()) @db.Uuid
  key   String @unique
  value String

  @@map("settings")
}

model ToolAuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  conversationId String?  @map("conversation_id") @db.Uuid
  toolCallId     String?  @map("tool_call_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  toolName       String   @map("tool_name")
  parameters     Json
  result         Json?
  success        Boolean?
  executionTime  Int?     @map("execution_time")
  approved       Boolean  @default(false)
  approvedBy     String?  @map("approved_by") @db.Uuid
  errorCode      String?  @map("error_code")
  policyBlocked  Boolean  @default(false) @map("policy_blocked")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@index([conversationId])
  @@map("tool_audit_logs")
}

model OrchestratorEvent {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  conversationId String?  @map("conversation_id") @db.Uuid
  type           String
  payload        Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@index([conversationId])
  @@map("orchestrator_events")
}

model MediaAsset {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  conversationId String?  @map("conversation_id") @db.Uuid
  source         String   @default("conversation_upload")
  mediaType      String   @map("media_type")
  mimeType       String?  @map("mime_type")
  originalPath   String   @map("original_path")
  thumbnailPath  String?  @map("thumbnail_path")
  hash           String?
  size           Int?
  width          Int?
  height         Int?
  duration       Float?
  status         String   @default("uploaded")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project           Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  processingResults MediaProcessingResult[]
  ocrBlocks         MediaOcrBlock[]
  layoutBlocks      MediaLayoutBlock[]
  tags              MediaTag[]

  @@index([projectId])
  @@index([conversationId])
  @@index([hash])
  @@map("media_assets")
}

model MediaProcessingResult {
  id                   String    @id @default(uuid()) @db.Uuid
  mediaAssetId         String    @map("media_asset_id") @db.Uuid
  processingMode       String    @default("balanced") @map("processing_mode")
  status               String    @default("pending")
  providerVersions     Json?     @map("provider_versions")
  resultJson           Json?     @map("result_json")
  contextMarkdownPath  String?   @map("context_markdown_path")
  error                Json?
  startedAt            DateTime? @map("started_at")
  finishedAt           DateTime? @map("finished_at")
  createdAt            DateTime  @default(now()) @map("created_at")

  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([mediaAssetId])
  @@map("media_processing_results")
}

model MediaOcrBlock {
  id           String   @id @default(uuid()) @db.Uuid
  mediaAssetId String   @map("media_asset_id") @db.Uuid
  provider     String
  text         String
  confidence   Float?
  bbox         Json?
  page         Int      @default(0)
  orderIndex   Int      @default(0) @map("order_index")
  createdAt    DateTime @default(now()) @map("created_at")

  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([mediaAssetId])
  @@map("media_ocr_blocks")
}

model MediaLayoutBlock {
  id           String   @id @default(uuid()) @db.Uuid
  mediaAssetId String   @map("media_asset_id") @db.Uuid
  provider     String
  blockType    String   @map("block_type")
  content      String
  confidence   Float?
  bbox         Json?
  orderIndex   Int      @default(0) @map("order_index")
  createdAt    DateTime @default(now()) @map("created_at")

  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([mediaAssetId])
  @@map("media_layout_blocks")
}

model MediaTag {
  id           String @id @default(uuid()) @db.Uuid
  mediaAssetId String @map("media_asset_id") @db.Uuid
  tag          String
  source       String
  confidence   Float?

  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([mediaAssetId])
  @@index([tag])
  @@map("media_tags")
}
