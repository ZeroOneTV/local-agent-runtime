# =============================================================================
# Backend no Windows (nativo) + Postgres/Redis/Open WebUI/workers no Docker
# Copie para backend/.env e ajuste caminhos WSL se necessário.
# =============================================================================

BACKEND_PORT=3001
NODE_ENV=development

# Com worker-all no Docker: use api (só HTTP — workers ficam nos containers)
# Sem workers no Docker: use all-in-one (API + filas no mesmo processo)
APP_ROLE=api

APP_PERFORMANCE_PROFILE=balanced

# LLM (Ollama no Windows)
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=deepseek-r1:8b
LLM_TIMEOUT_MS=120000
LLM_STREAMING=true

# Postgres / Redis (Docker exposto em localhost)
DATABASE_URL=postgresql://local_ai:local_ai_password@localhost:5432/local_ai_assistant
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

VECTOR_STORE=pgvector

# Storage compartilhado com containers (mesma pasta que ./storage no WSL)
# Ajuste Ubuntu-24.04 / zero se seu WSL for diferente
STORAGE_PATH=\\wsl.localhost\Ubuntu-24.04\home\zero\my_llm\storage
UPLOADS_PATH=\\wsl.localhost\Ubuntu-24.04\home\zero\my_llm\storage\uploads
PROJECTS_PATH=\\wsl.localhost\Ubuntu-24.04\home\zero\my_llm\storage\projects
TEMP_PATH=\\wsl.localhost\Ubuntu-24.04\home\zero\my_llm\storage\temp
ARTIFACTS_PATH=\\wsl.localhost\Ubuntu-24.04\home\zero\my_llm\storage\artifacts
MEDIA_STORAGE_ROOT=\\wsl.localhost\Ubuntu-24.04\home\zero\my_llm\storage\media
MEMORY_STORAGE_ROOT=\\wsl.localhost\Ubuntu-24.04\home\zero\my_llm\storage\memory
STORAGE_TEMP_MAX_AGE_HOURS=24
STORAGE_ARTIFACT_MAX_AGE_DAYS=30

# Open WebUI (container Docker → backend no host)
OPENWEBUI_PORT=3080
OPENWEBUI_URL=http://localhost:3080
OPENWEBUI_API_KEY=local-dev-key
OPENWEBUI_REQUIRE_API_KEY=false
OPENWEBUI_LOGICAL_MODELS=local-assistant|Local Assistant|00000000-0000-4000-8000-000000000001,local-coder|Local Coder|00000000-0000-4000-8000-000000000001,local-fast|Local Fast|00000000-0000-4000-8000-000000000001
OPENWEBUI_API_KEY_PROJECT_MAP=local-dev-key|00000000-0000-4000-8000-000000000001
OPENWEBUI_WEBHOOK_URLS=
OPENWEBUI_APPROVALS_BASE_URL=http://localhost:3001

# Media worker (Docker profile media → localhost:5000)
MEDIA_WORKER_URL=http://localhost:5000
MEDIA_WORKER_TIMEOUT_MS=120000
MEDIA_MAX_IMAGE_SIZE_MB=25
MEDIA_MAX_IMAGE_WIDTH=8000
MEDIA_MAX_IMAGE_HEIGHT=8000
MEDIA_DEFAULT_PROCESSING_MODE=balanced
MEDIA_ENABLE_VLM=false
MEDIA_GENERATE_THUMBNAILS=true
MEDIA_REQUIRE_CONFIRMATION_TO_INDEX=true
MEDIA_WAIT_FOR_PROCESSING_MS=5000
MEDIA_PROCESSING_TIMEOUT_MS=180000
MEDIA_OCR_PRIMARY=paddleocr
MEDIA_ENABLE_PADDLEOCR=false
MEDIA_ENABLE_TESSERACT_FALLBACK=true
MEDIA_OCR_LANGUAGES=pt,en
MEDIA_ENABLE_PP_STRUCTURE=false
MEDIA_ENABLE_DOCLING=false
MEDIA_DOCLING_ONLY_FOR_DOCUMENTS=true
MEDIA_VLM_PROVIDER=ollama
MEDIA_VLM_MODEL=qwen2.5vl:7b
MEDIA_VLM_BASE_URL=http://localhost:11434
MEDIA_VLM_MAX_IMAGE_SIZE=1280
MEDIA_THUMBNAIL_FORMAT=webp

# Filesystem nativo — discovery dinâmico (sem paths fixos obrigatórios)
HOST_FILESYSTEM_ENABLED=true
HOST_FILESYSTEM_MODE=native
HOST_FILESYSTEM_DISCOVERY_ENABLED=true
HOST_FILESYSTEM_ALLOW_DRIVE_DISCOVERY=true
HOST_FILESYSTEM_ALLOW_HOME_DISCOVERY=true
HOST_FILESYSTEM_DEFAULT_READ=true
HOST_FILESYSTEM_ALLOW_BROWSE=true
HOST_FILESYSTEM_ALLOW_READ=true
HOST_FILESYSTEM_ALLOW_WRITE=false
HOST_FILESYSTEM_REQUIRE_APPROVAL_FOR_WRITE=true
HOST_FILESYSTEM_REQUIRE_APPROVAL_FOR_DELETE=true
HOST_FILESYSTEM_BLOCK_SENSITIVE_PATHS=true
HOST_FILESYSTEM_AUDIT_ENABLED=true
HOST_FILESYSTEM_ALLOWED_DRIVES=C,D,E
HOST_FILESYSTEM_DEFAULT_ACCESS=read
# Overrides opcionais (avançado) — discovery usa os.homedir() por padrão
# HOST_USER_HOME=
# HOST_DOCUMENTS_PATH=
# HOST_DESKTOP_PATH=
# HOST_DOWNLOADS_PATH=

# Agentic tool use
AGENTIC_TOOL_USE=true
AGENTIC_AUTO_EXECUTE_READONLY=true
AUTO_TOOL_MAX_CALLS_PER_TURN=3
APPROVAL_BASE_URL=http://localhost:3001
TOOL_GRANTS_ENABLED=true
# Aprovação para tools kind=external (web_search/fetch_url)
AGENTIC_REQUIRE_APPROVAL_FOR_EXTERNAL=true

# Acesso à internet — opt-in, desligado por padrão (assistente local/privado).
# Ligue web_search apontando para uma instância SearXNG (JSON habilitado) ou Brave.
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=disabled
WEB_SEARCH_SEARXNG_URL=
WEB_SEARCH_BRAVE_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_MS=10000
# fetch_url: leitura de páginas públicas com proteção SSRF (bloqueia IPs internos)
WEB_FETCH_ENABLED=false
WEB_FETCH_MAX_BYTES=2000000

# Segurança / contexto (defaults sensatos)
TOOL_EXECUTION_MODE=approval_required
ALLOW_SHELL_COMMANDS=false
MAX_CONTEXT_TOKENS=24000
CONTEXT_RECENT_MESSAGES=15
CONTEXT_MEMORY_LIMIT=5
CONTEXT_RAG_CHUNK_LIMIT=5
EMBEDDING_MODEL=nomic-embed-text

# Memory stratification
MEMORY_WORKING_TTL_HOURS=72
MEMORY_WORKING_PROJECT_TTL_DAYS=7
MEMORY_RECENT_TTL_DAYS=30
MEMORY_DEEP_ARCHIVE_AFTER_DAYS=180
MEMORY_ACCESS_REFRESH=true
MEMORY_RETRIEVAL_ENABLE_DEEP=true
MEMORY_RETRIEVAL_ENABLE_ARCHIVE=false
MEMORY_RETRIEVAL_MAX_RECENT=5
MEMORY_RETRIEVAL_MAX_CONSOLIDATED=5
MEMORY_RETRIEVAL_MAX_DEEP=3
MEMORY_EXPORT_DEFAULT_PROFILE=portable
MEMORY_EXPORT_INCLUDE_WORKING=false
MEMORY_EXPORT_INCLUDE_AUDIT=false
MEMORY_IMPORT_DEFAULT_MODE=new_project
MEMORY_IMPORT_AUTO_REEMBED=true
MEMORY_EXPORT_MAX_SIZE_MB=2048
