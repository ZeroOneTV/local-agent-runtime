    "@types/express": "^5.0.0",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.10.2",
    "prisma": "^6.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
