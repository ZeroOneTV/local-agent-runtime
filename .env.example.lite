# Perfil lite (~8 GB RAM) — copie sobre .env ou mescle com .env.example
APP_PERFORMANCE_PROFILE=lite
APP_ROLE=api
NODE_OPTIONS=--max-old-space-size=384

MAX_CONTEXT_TOKENS=4096
CONTEXT_RECENT_MESSAGES=6
CONTEXT_MAX_RECENT_TOKENS=1500
CONTEXT_SKIP_RAG_CASUAL=true
RAG_TOP_K=3

JOBS_ORCHESTRATOR_CONCURRENCY=1
JOBS_INDEXING_CONCURRENCY=1
JOBS_EMBEDDINGS_CONCURRENCY=1
JOBS_TOOLS_CONCURRENCY=1
JOBS_MEMORY_CONCURRENCY=1
JOBS_MEDIA_CONCURRENCY=1

MEMORY_RETRIEVAL_MAX_RECENT=3
MEMORY_RETRIEVAL_MAX_CONSOLIDATED=3
MEMORY_RETRIEVAL_MAX_DEEP=1
MEMORY_RETRIEVAL_ENABLE_ARCHIVE=false

MEDIA_DEFAULT_PROCESSING_MODE=fast
MEDIA_ENABLE_VLM=false
MEDIA_ENABLE_DOCLING=false

RESOURCE_GUARD_ENABLED=true
RESOURCE_GUARD_MAX_RAM_PERCENT=70
RESOURCE_GUARD_MAX_CPU_PERCENT=80

TOOL_RESULT_INLINE_MAX_KB=24
CONTEXT_ARTIFACT_PREVIEW_MAX_KB=8

REDIS_MAXMEMORY=128mb
POSTGRES_SHARED_BUFFERS=128MB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_EFFECTIVE_CACHE_SIZE=512MB
