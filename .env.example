# App
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_PORT=3000

# LLM local rodando fora do Docker
LLM_PROVIDER=ollama
LLM_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=qwen3:14b

# Database
POSTGRES_USER=local_ai
POSTGRES_PASSWORD=local_ai_password
POSTGRES_DB=local_ai_assistant
DATABASE_URL=postgresql://local_ai:local_ai_password@postgres:5432/local_ai_assistant

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# Vector Store
VECTOR_STORE=pgvector
QDRANT_URL=http://qdrant:6333

# Storage
STORAGE_PATH=/storage
UPLOADS_PATH=/storage/uploads
PROJECTS_PATH=/storage/projects
TEMP_PATH=/storage/temp

# Security
TOOL_EXECUTION_MODE=approval_required
ALLOW_SHELL_COMMANDS=false
MAX_CONTEXT_TOKENS=24000

# Context Engine
CONTEXT_RECENT_MESSAGES=15
CONTEXT_SUMMARY_MESSAGE_THRESHOLD=3
CONTEXT_SUMMARY_TOKEN_THRESHOLD=500
CONTEXT_MEMORY_LIMIT=5
CONTEXT_RAG_CHUNK_LIMIT=5
CONTEXT_TOOL_RESULTS_LIMIT=5
CONTEXT_HIGH_IMPORTANCE_THRESHOLD=4

# RAG & Embeddings
EMBEDDING_MODEL=nomic-embed-text
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# Tools
TOOL_MAX_OUTPUT_CHARS=4000
TOOL_COMMAND_TIMEOUT_MS=30000
TOOL_FETCH_TIMEOUT_MS=10000

# Security
SECURITY_MAX_CONSECUTIVE_CALLS=20
SECURITY_MAX_DIRECTORY_DEPTH=8
SECURITY_MAX_FILES_PER_SEARCH=100
SECURITY_SHELL_ALLOWLIST=npm,git,node,ls,cat,pwd,echo,npx
SECURITY_DISABLED_TOOLS=
SECURITY_AUTONOMOUS_TOOLS=read_file,list_directory,search_files,git_status,search_rag
SECURITY_BLOCK_DELETE_PRODUCTION=true
SECURITY_BLOCK_BROWSER_OFFLINE=true

# Cognitive Orchestrator
COGNITIVE_MAX_CYCLES=8
COGNITIVE_MAX_CONSECUTIVE_TOOLS=3
COGNITIVE_REQUIRE_MEMORY_CONFIRMATION=true
COGNITIVE_DEFAULT_MODE=assisted_executor
COGNITIVE_ENABLE_REFLECTION=true
COGNITIVE_ENABLE_LONG_JOBS=true
COGNITIVE_EVENT_SYSTEM=true
COGNITIVE_DEBUG=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DEFAULT_PROJECT_ID=00000000-0000-4000-8000-000000000001

# Open WebUI Integration
OPENWEBUI_PORT=3080
OPENWEBUI_API_KEY=local-dev-key
OPENWEBUI_REQUIRE_API_KEY=false
OPENWEBUI_LOGICAL_MODELS=local-assistant|Local Assistant|00000000-0000-4000-8000-000000000001,local-coder|Local Coder|00000000-0000-4000-8000-000000000001,local-fast|Local Fast|00000000-0000-4000-8000-000000000001
OPENWEBUI_API_KEY_PROJECT_MAP=local-dev-key|00000000-0000-4000-8000-000000000001
OPENWEBUI_WEBHOOK_URLS=
OPENWEBUI_APPROVALS_BASE_URL=http://localhost:3001
OPENWEBUI_URL=http://localhost:3080

# Media Processing (images)
MEDIA_STORAGE_ROOT=/storage/media
MEDIA_WORKER_URL=http://media-worker:5000
MEDIA_WORKER_TIMEOUT_MS=120000
MEDIA_MAX_IMAGE_SIZE_MB=25
MEDIA_MAX_IMAGE_WIDTH=8000
MEDIA_MAX_IMAGE_HEIGHT=8000
MEDIA_DEFAULT_PROCESSING_MODE=balanced
MEDIA_ENABLE_VLM=false
MEDIA_GENERATE_THUMBNAILS=true
MEDIA_REQUIRE_CONFIRMATION_TO_INDEX=true
MEDIA_WAIT_FOR_PROCESSING_MS=5000
MEDIA_WORKER_PORT=5000
