# App
NODE_ENV=development
BACKEND_PORT=3001
APP_PERFORMANCE_PROFILE=balanced
# api = só HTTP; all-in-one = API + processors (dev local); worker-* = containers separados
APP_ROLE=all-in-one

# LLM local rodando fora do Docker
LLM_PROVIDER=ollama
LLM_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=qwen3:14b

# Database
POSTGRES_USER=local_ai
POSTGRES_PASSWORD=local_ai_password
POSTGRES_DB=local_ai_assistant
DATABASE_URL=postgresql://local_ai:local_ai_password@postgres:5432/local_ai_assistant
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_WORK_MEM=8MB
POSTGRES_MAINTENANCE_WORK_MEM=128MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
REDIS_MAXMEMORY=256mb

# Vector Store
VECTOR_STORE=pgvector
QDRANT_URL=http://qdrant:6333

# Storage
STORAGE_PATH=/storage
UPLOADS_PATH=/storage/uploads
PROJECTS_PATH=/storage/projects
TEMP_PATH=/storage/temp

# Security
TOOL_EXECUTION_MODE=approval_required
ALLOW_SHELL_COMMANDS=false
MAX_CONTEXT_TOKENS=24000

# Context Engine
CONTEXT_RECENT_MESSAGES=15
CONTEXT_SUMMARY_MESSAGE_THRESHOLD=3
CONTEXT_SUMMARY_TOKEN_THRESHOLD=500
CONTEXT_MEMORY_LIMIT=5
CONTEXT_RAG_CHUNK_LIMIT=5
CONTEXT_TOOL_RESULTS_LIMIT=5
CONTEXT_HIGH_IMPORTANCE_THRESHOLD=4

# RAG & Embeddings
EMBEDDING_MODEL=nomic-embed-text
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# Tools
TOOL_MAX_OUTPUT_CHARS=4000
TOOL_COMMAND_TIMEOUT_MS=30000
TOOL_FETCH_TIMEOUT_MS=10000

# Security
SECURITY_MAX_CONSECUTIVE_CALLS=20
SECURITY_MAX_DIRECTORY_DEPTH=8
SECURITY_MAX_FILES_PER_SEARCH=100
SECURITY_SHELL_ALLOWLIST=npm,git,node,ls,cat,pwd,echo,npx
SECURITY_DISABLED_TOOLS=
SECURITY_AUTONOMOUS_TOOLS=read_file,list_directory,search_files,git_status,search_rag
SECURITY_BLOCK_DELETE_PRODUCTION=true
SECURITY_BLOCK_BROWSER_OFFLINE=true

# Cognitive Orchestrator
COGNITIVE_MAX_CYCLES=8
COGNITIVE_MAX_CONSECUTIVE_TOOLS=3
COGNITIVE_REQUIRE_MEMORY_CONFIRMATION=true
COGNITIVE_DEFAULT_MODE=assisted_executor
COGNITIVE_ENABLE_REFLECTION=true
COGNITIVE_ENABLE_LONG_JOBS=true
COGNITIVE_EVENT_SYSTEM=true
COGNITIVE_DEBUG=false

# Open WebUI Integration
OPENWEBUI_PORT=3080
OPENWEBUI_API_KEY=local-dev-key
OPENWEBUI_REQUIRE_API_KEY=false
OPENWEBUI_LOGICAL_MODELS=local-assistant|Local Assistant|00000000-0000-4000-8000-000000000001,local-coder|Local Coder|00000000-0000-4000-8000-000000000001,local-fast|Local Fast|00000000-0000-4000-8000-000000000001
OPENWEBUI_API_KEY_PROJECT_MAP=local-dev-key|00000000-0000-4000-8000-000000000001
OPENWEBUI_WEBHOOK_URLS=
OPENWEBUI_APPROVALS_BASE_URL=http://localhost:3001
OPENWEBUI_URL=http://localhost:3080

# Media Processing (images)
MEDIA_STORAGE_ROOT=/storage/media
MEDIA_WORKER_URL=http://media-worker:5000
MEDIA_WORKER_TIMEOUT_MS=120000
MEDIA_MAX_IMAGE_SIZE_MB=25
MEDIA_MAX_IMAGE_WIDTH=8000
MEDIA_MAX_IMAGE_HEIGHT=8000
MEDIA_DEFAULT_PROCESSING_MODE=balanced
MEDIA_ENABLE_VLM=false
MEDIA_GENERATE_THUMBNAILS=true
MEDIA_REQUIRE_CONFIRMATION_TO_INDEX=true
MEDIA_WAIT_FOR_PROCESSING_MS=5000
MEDIA_WORKER_PORT=5000
MEDIA_WORKER_CONCURRENCY=1
MEDIA_PROCESSING_TIMEOUT_MS=180000

# OCR providers (enable after building worker with MEDIA_INSTALL_OCR=true)
MEDIA_OCR_PRIMARY=paddleocr
MEDIA_ENABLE_PADDLEOCR=false
MEDIA_ENABLE_TESSERACT_FALLBACK=true
MEDIA_OCR_LANGUAGES=pt,en
MEDIA_INSTALL_OCR=false

# Layout / document (enable after building with INSTALL_DOCLING=true)
MEDIA_ENABLE_PP_STRUCTURE=false
MEDIA_ENABLE_DOCLING=false
MEDIA_DOCLING_ONLY_FOR_DOCUMENTS=true
MEDIA_INSTALL_DOCLING=false

# Vision (optional — requires model running natively via Ollama)
MEDIA_VLM_PROVIDER=ollama
MEDIA_VLM_MODEL=qwen2.5vl:7b
MEDIA_VLM_BASE_URL=http://host.docker.internal:11434
MEDIA_VLM_MAX_IMAGE_SIZE=1280
MEDIA_THUMBNAIL_FORMAT=webp

# Optimization — Context budget
CONTEXT_MAX_RECENT_TOKENS=3000
CONTEXT_SKIP_RAG_CASUAL=true
RAG_TOP_K=5

# Resource guard & artifacts
RESOURCE_GUARD_ENABLED=true
RESOURCE_GUARD_MAX_RAM_PERCENT=80
RESOURCE_GUARD_MAX_CPU_PERCENT=85
RESOURCE_GUARD_PAUSE_LOW_PRIORITY=true
RESOURCE_GUARD_CHECK_INTERVAL_MS=5000
TOOL_RESULT_INLINE_MAX_KB=32
CONTEXT_ARTIFACT_PREVIEW_MAX_KB=16

# Optimization — Jobs concurrency
JOBS_ORCHESTRATOR_CONCURRENCY=1
JOBS_INDEXING_CONCURRENCY=1
JOBS_EMBEDDINGS_CONCURRENCY=1
JOBS_MEDIA_CONCURRENCY=1
JOBS_TOOLS_CONCURRENCY=2
JOBS_MEMORY_CONCURRENCY=1

# Optimization — LLM
LLM_TIMEOUT_MS=120000
LLM_STREAMING=true

# Optimization — Storage
ARTIFACTS_PATH=/storage/artifacts
STORAGE_TEMP_MAX_AGE_HOURS=24
STORAGE_ARTIFACT_MAX_AGE_DAYS=30

# Memory Stratification
MEMORY_WORKING_TTL_HOURS=72
MEMORY_WORKING_PROJECT_TTL_DAYS=7
MEMORY_RECENT_TTL_DAYS=30
MEMORY_DEEP_ARCHIVE_AFTER_DAYS=180
MEMORY_ACCESS_REFRESH=true
MEMORY_RETRIEVAL_ENABLE_DEEP=true
MEMORY_RETRIEVAL_ENABLE_ARCHIVE=false
MEMORY_RETRIEVAL_MAX_RECENT=5
MEMORY_RETRIEVAL_MAX_CONSOLIDATED=5
MEMORY_RETRIEVAL_MAX_DEEP=3
MEMORY_EXPORT_DEFAULT_PROFILE=portable
MEMORY_EXPORT_INCLUDE_WORKING=false
MEMORY_EXPORT_INCLUDE_AUDIT=false
MEMORY_EXPORT_ENCRYPTION=false
MEMORY_IMPORT_DEFAULT_MODE=new_project
MEMORY_IMPORT_AUTO_REEMBED=true
MEMORY_EXPORT_MAX_SIZE_MB=2048
MEMORY_STORAGE_ROOT=/storage/memory
