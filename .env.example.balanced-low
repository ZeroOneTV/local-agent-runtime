# Perfil balanced-low (~16 GB RAM)
APP_PERFORMANCE_PROFILE=balanced-low
APP_ROLE=api
NODE_OPTIONS=--max-old-space-size=512

MAX_CONTEXT_TOKENS=6144
CONTEXT_RECENT_MESSAGES=8
CONTEXT_SKIP_RAG_CASUAL=true
RAG_TOP_K=4

JOBS_ORCHESTRATOR_CONCURRENCY=1
JOBS_INDEXING_CONCURRENCY=1
JOBS_EMBEDDINGS_CONCURRENCY=1
JOBS_TOOLS_CONCURRENCY=1
JOBS_MEMORY_CONCURRENCY=1
JOBS_MEDIA_CONCURRENCY=1

MEMORY_RETRIEVAL_MAX_RECENT=4
MEMORY_RETRIEVAL_MAX_CONSOLIDATED=4
MEMORY_RETRIEVAL_MAX_DEEP=1

MEDIA_DEFAULT_PROCESSING_MODE=balanced
MEDIA_ENABLE_VLM=false
MEDIA_ENABLE_DOCLING=false

RESOURCE_GUARD_MAX_RAM_PERCENT=75
RESOURCE_GUARD_MAX_CPU_PERCENT=85

TOOL_RESULT_INLINE_MAX_KB=32
CONTEXT_ARTIFACT_PREVIEW_MAX_KB=12

REDIS_MAXMEMORY=256mb
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_WORK_MEM=8MB
POSTGRES_MAINTENANCE_WORK_MEM=128MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
